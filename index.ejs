<!-- or you can simply write because we are using ejs-mate that means we dont need to build same things again and again for different pages-->

<% layout("/layouts/boilerplate.ejs")%>

    <body>
        <h3>All Listings</h3>
        <!-- <form method="GET" action="/listings/new">
        <button>Create New Listing</button>
    </form> -->
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 row-cols-1">
        <% for(let listing of allListings){ %>
            <a href="/listings/<%=listing._id%>" class="listing-links">
            <div class="card col">
                <img src="<%= listing.image.url%>" class="card-img-top" alt="listing_image" style="height: 20rem ;">
                <div class="card-img-overlay"></div>
                <div class="card-body">
                    <p class="card-text">
                        <b><%=listing.title%></b> <br>
                        <b><u>&#8377;  <%=listing.price.toLocaleString("en-IN")%></u></b> for 1 night
                    </p>
                </div>
            </div>
        </a>
            <%}%>
