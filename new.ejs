<% layout("/layouts/boilerplate.ejs")%>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h3>Create A New Listing</h3>
            <form method="post" action="/listings" novalidate class="needs-validation">


                <div class="mb-3">
                    <label for="title" class="form-label">Title:</label>
                    <input type="text" name="listing[title]" placeholder="Add a catchy title" class="form-control" required>
                    <div class="invalid-feedback">Please add a tittle</div>
                </div>


                <div class="mb-3">
                    <label for="desription" class="form-label">Description:</label>
                    <textarea name="listing[description]" class="form-control"
                        placeholder="Share details about your place" required></textarea>
                    <div class="invalid-feedback">Please add valid description</div>
                </div>


                <div class="mb-3">
                    <label for="image" class="form-label">Image Link:</label>
                    <input type="text" name="listing[image][url]" placeholder="Enter image URL/Link"
                        class="form-control">
                </div>


                <div class="row">

                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price:</label>
                        <input type="number" name="listing[price]" placeholder="Enter price" class="form-control"
                            min="100" required>
                        <div class="invalid-feedback">Please add valid amount</div>
                    </div>

                    <div class="mb-3 col-md-8">
                        <label class="form-label">Country:</label>
                        <input type="text" name="listing[country]" placeholder="Enter Country" class="form-control"
                            pattern="[A-Za-z\s]+" required>
                        <div class="invalid-feedback">Country name should be valid</div>
                    </div>

                </div>



                <div class="row">

                    <div class="mb-3 col-md-4">
                        <label for="state" class="form-label">State:</label>
                        <input type="text" name="listing[state]" placeholder="Enter State" class="form-control"
                            pattern="[A-Za-z\s]+" required>
                        <div class="invalid-feedback">Please enter valid state</div>
                    </div>

                    <div class="mb-3 col-md-4">
                        <label for="city" class="form-label">City:</label>
                        <input type="text" name="listing[city]" placeholder="Enter City" class="form-control"
                            pattern="[A-Za-z\s]+" required>
                        <div class="invalid-feedback">Please add a valid City</div>
                    </div>

                    <div class="mb-3 col-md-4">
                        <label for="zip" class="form-label">Zip-Code:</label>
                        <input type="number" name="listing[zip]" placeholder="Enter Zip Code" class="form-control"
                            required>
                        <div class="invalid-feedback">Please add a valid zip code</div>
                    </div>

                </div>


                <div class="mb-3">
                    <label for="location" class="form-label">Location:</label>
                    <input type="text" name="listing[location]"
                        placeholder="Tell guests about your location and nearby highlights" class="form-control"
                        required>
                    <div class="invalid-feedback">Please add your location</div>
                </div>


                <div class="mb-3">
                    <label for="about" class="form-label">About me:</label>
                    <textarea name="listing[about]" placeholder="Tell others something fun and punchy about you"
                        class="form-control"></textarea>
                </div>


                <button type="submit" class="btn btn-dark mt-3 add-btn">Submit</button><br><br>
            </form>
        </div>
    </div>
</body>

















