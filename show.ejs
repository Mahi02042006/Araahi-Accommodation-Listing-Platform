<% layout("/layouts/boilerplate.ejs")%>
    <div class="row mt-3">
        <div class="col-6 offset-3 show-head">

            <body>
                <h3><u><b>Listing Details</b></u></h3><br>
        </div>
        <div class="card col-6 show-card" style="width: 35rem; margin: auto;">
            <img src="<%= listing.image.url%>" class="card-img-top show-img" alt="listing_image">
            <div class="card-body">
                <p class="card-text">
                    <b>
                        <%=listing.title%>
                    </b> <br>
                    <%=listing.description%> <br>
                        &#8377; <%=listing.price.toLocaleString("en-IN")%> <br>
                            <%=listing.location%> <br>
                            <%=listing.city%> <br>
                            <%=listing.state%> <br>
                            Zip-Code: <%=listing.zip%> <br>
                                <%=listing.country%>
                </p>
            </div>
        </div>
    </div>
    <br>
    <div class="btns">
        <a href="/listings/<%=listing._id%>/edit" class="btn btn-primary col-2 offset-4">Edit</a>
        <form method="post" action="/listings/<%=listing._id%>?_method=DELETE">
            <button class="btn btn-danger offset-6">Delete</button>
        </form>
    </div>
    <br><br>